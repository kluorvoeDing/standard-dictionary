    "full_name": "GB 47372-2026 Safety technical specification for power bank",
    "full_name_zh": "GB 47372—2026 移動電源安全技術規範",
    "short_name": "GB 47372-2026",
    "publisher": "國家市場監督管理總局、國家標準化管理委員會",
    "publication_date": "2026-03-31發佈 2027-04-01實施",
    "type": "standard",
    "scope": "規定了移動電源的安全要求，描述了相應的試驗方法。適用於額定輸入電壓為交流 220 V 和/或直流不大於 250 V，輸出電壓為直流和/或交流的移動電源。",
    "applicable_objects": [
      "CELL",
      "PACK_SYSTEM"
    ],
    "source_pdf": "GB47372-2026.pdf",
    "source_gemini_md": ""
  },
  "terms": [
    {
      "term_en": "power bank",
      "term_zh": "移動電源",
      "definition": "預定能由使用人員攜帶的，由電池或電池組、相應的電路及外殼組成，能提供穩定直流和/或交流輸出，且質量不超過 18 kg 的電源系統。"
    },
    {
      "term_en": "portable power bank",
      "term_zh": "便攜式移動電源",
      "definition": "所含的電池或電池組總額定能量不大於 160 Wh 的移動電源。"
    },
    {
      "term_en": "portable energy storage",
      "term_zh": "便攜式儲能電源",
      "definition": "所含的電池或電池組總額定能量大於 160 Wh 的移動電源。"
    },
    {
      "term_en": "thermal runaway",
      "term_zh": "熱失控",
      "definition": "由放熱反應引起的電池發生不可控溫升的現象。"
    }
  ],
