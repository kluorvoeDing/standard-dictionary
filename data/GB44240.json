      "test_objects": [
        "CELL"
      ],
      "conditions": {
        "temperature": {
          "value": "57 ± 4°C",
          "detail": "放置在 57 ± 4°C 的環境中，待電池達到溫度後再放置 30 min。"
        },
        "resistance": {
          "value": "≤ 5 mΩ",
          "detail": "用導線連接電池正負極端，確保全部外部電阻不高於 5 mΩ。"
        },
        "termination": {
          "value": "溫度下降至峰值溫升 80% 或達 6 h",
          "detail": "當電池溫度下降值達到峰值溫升的 80% 或短接時間達到 6 h 時終止（選較嚴者）。"
        }
      },
      "acceptance_criteria": {
        "summary": "不起火、不爆炸",
        "details": [
          "試驗終止後觀察 1 h，電池應不起火、不爆炸。"
        ]
      },
      "exemptions": [],
      "related_tests": [],
      "source_reference": "6.1",
      "original_text_snippet": "Then the cell or battery at 57 ± 4 °C shall be subjected to one short circuit condition with a total external resistance of less than 5 mΩ."
    },
